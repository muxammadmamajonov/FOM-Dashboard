# ---------------------------------------------------------------------------
# FOM Dashboard Bot — environment configuration template.
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#   cp .env.example .env && chmod 600 .env
# ---------------------------------------------------------------------------

# === Telegram (required) ===================================================

# Bot token from @BotFather. Format: "<id>:<hash>".
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Numeric Telegram user id allowed to upload dashboards. Get it from @userinfobot.
ADMIN_USER_ID=123456789

# Group/supergroup chat id to notify. Must be negative (supergroups start -100).
TELEGRAM_GROUP_CHAT_ID=-1001234567890

# === Dashboard public URL (required) =======================================

# The Worker's *.workers.dev URL (or your own custom domain) AFTER you deploy
# `worker/`. Used for the group's "Open in Browser" fallback button.
#   cd worker && npx wrangler deploy   # prints this URL
CLOUDFLARE_DOMAIN=https://fom-dashboard.your-subdomain.workers.dev

# === R2 storage (required) =================================================
# The Python bot writes the dashboard here; the Worker reads it from here.
# Get all of these from the Cloudflare dashboard:
#   - Account ID:        top-right of the R2 page
#   - API token keys:    R2 -> "Manage R2 API Tokens" -> Create -> Object R/W
#   - Bucket:            R2 -> create one (e.g. "fom-dashboard")

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=fom-dashboard

# === Telegram Mini App / fullscreen (optional) =============================

# Inject the Telegram Web App SDK + fullscreen bootstrap into every saved
# dashboard so it opens fullscreen when launched as a Mini App. Default: true
WEBAPP_FULLSCREEN_ENABLED=true

# BotFather Mini App short name. When set, the group "View Dashboard" button
# opens https://t.me/<your_bot>/<WEBAPP_SHORT_NAME> as a fullscreen Mini App.
# Leave empty to use a plain browser link instead.
WEBAPP_SHORT_NAME=dashboard

# === Application (optional) ================================================

# Keep timestamped backups (in R2 under `backups/`). Default: true
BACKUP_ENABLED=true

# Maximum accepted upload size in bytes. Default: 52428800 (50 MB).
# NOTE: Telegram limits *bot downloads* to 20 MB regardless of this value.
MAX_FILE_SIZE=52428800

# Console log level: DEBUG | INFO | WARNING | ERROR | CRITICAL. Default: INFO
LOG_LEVEL=INFO
